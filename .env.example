APP_PORT=8080
APP_ENV=development
HTTP_WRITE_TIMEOUT_SECONDS=300

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=academyprometheus

JWT_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
AUTH_OTP_SECRET=replace-with-long-random-otp-secret

MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_ENV=sandbox
PAYMENT_EXPIRES_MINUTES=30

STORAGE_PATH=storage
STORAGE_PROVIDER=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_SIGNED_URL_TTL_SECONDS=300
BACKUP_R2_BUCKET=
BACKUP_R2_ACCESS_KEY_ID=
BACKUP_R2_SECRET_ACCESS_KEY=
CHROMIUM_PATH=
PDF_RENDER_TIMEOUT_SECONDS=30
PDF_RENDER_CONCURRENCY=2
CWEBP_BIN=cwebp
BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=600
AUTH_RATE_LIMIT_PER_MINUTE=10
OTP_VERIFY_RATE_LIMIT_PER_MINUTE=10
OTP_RESEND_RATE_LIMIT_PER_MINUTE=3
PASSWORD_RESET_RATE_LIMIT_PER_MINUTE=5
AUTH_OTP_MAX_ATTEMPTS=5

# GoHighLevel is configured from Admin Settings in the database.
# Required: Private Integration access token and Location ID. Keep tokens out of committed files.
# Signed provider callbacks for delivered/open/click/bounce/complaint/unsubscribe/conversion events.
EMAIL_EVENT_WEBHOOK_SECRET=change-me
